[Unit]
Description=Onifast Panel Server
After=network.target mysql.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/root/onifast
ExecStart=/usr/local/bin/onifast-panel
Restart=always
RestartSec=5
StandardOutput=append:/var/log/onifast/panel.log
StandardError=append:/var/log/onifast/panel.log

[Install]
WantedBy=multi-user.target
